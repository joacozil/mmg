---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "MMG Bank | Soluciones globales para clientes ambiciosos", 
	description = "En MMG Bank somos su socio estratégico en asesoría financiera, diseñados para acompañarle en su evolución y expansión con estrategias sólidas y diversificadas." 
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<script is:inline>
			// Disable browser scroll restoration – GSAP's pin spacer changes
			// document height, making the browser's restored position wrong.
			// We handle restoration manually after GSAP sets up.
			if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
			window.addEventListener('beforeunload', function() {
				try { sessionStorage.setItem('__mmg_scrollY', String(window.scrollY)); } catch(e) {}
			});
		</script>
	</head>
	<body>
		<slot />
		<script is:inline>
			// Restore scroll BEFORE React hydrates (inline scripts run before
			// deferred/module scripts). This gets us to ~the right position
			// so GSAP's isScrolledPastHero check works correctly.
			try {
				var __y = parseInt(sessionStorage.getItem('__mmg_scrollY') || '0', 10);
				if (__y > 0) window.scrollTo(0, __y);
			} catch(e) {}

			// Smooth scroll to anchors
			document.addEventListener('click', function(e) {
				const target = e.target.closest('a[href^="#"]');
				if (target) {
					const href = target.getAttribute('href');
					if (href.startsWith('#') && href !== '#') {
						const el = document.querySelector(href);
						if (el) {
							e.preventDefault();
							el.scrollIntoView({ behavior: 'smooth' });
						}
					}
				}
			});
		</script>
	</body>
</html>
