          </svg>
        </a>
      </div>

      <!-- Right: "En Línea" Dropdown (Hidden on mobile, Right on sm+) -->
      <div class="hidden sm:flex justify-end sm:col-start-3 sm:row-start-1">
        <EnLineaDropdown />
      </div>

      <!-- Left: Hamburger Button (Right on mobile, Left on sm+) -->
      <div
        class="flex justify-end sm:justify-start sm:col-start-1 sm:row-start-1"
      >
        <button
          id="menu-toggle"
          class="flex flex-col justify-center items-center w-8 h-8 z-1000 relative focus:outline-none cursor-pointer"
          aria-label="Toggle menu"
        >
          <!-- Hamburger Icon Wrapper -->
          <div class="relative w-6 h-5">
            <span
              class="hamburger-line absolute left-0 top-[2px] w-full h-0.5 transition-all duration-300 origin-center"
            ></span>
            <span
              class="hamburger-line absolute left-0 top-[9px] w-full h-0.5 transition-all duration-300"
            ></span>
            <span
              class="hamburger-line absolute left-0 top-[16px] w-full h-0.5 transition-all duration-300 origin-center"
            ></span>
          </div>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Drawer Backdrop Overlay (outside transform header context) -->
<div
  id="drawer-backdrop"
  class="fixed inset-0 bg-black/60 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-500 z-997"
>
</div>

<!-- Drawer Menu Panel (outside transform header context) -->
<div
  id="drawer-menu"
  class="fixed left-0 top-0 h-full w-full max-w-full lg:max-w-[450px] text-cream flex flex-col justify-between px-(--element-padding) py-8 md:py-12 lg:p-16 transform -translate-x-full transition-transform duration-500 ease-out z-998 shadow-2xl overflow-y-auto"
>
  <!-- Content Space -->
  <div class="mt-24 flex-1 flex flex-col justify-center">
    <nav class="flex flex-col gap-5 md:gap-7 uppercase font-bold">
      <a href="#cliente" class="drawer-nav-link">Cliente</a>
      <a href="#soluciones" class="drawer-nav-link">Soluciones de Inversión</a>
      <a href="#servicios" class="drawer-nav-link">Servicios Bancarios</a>
      <a href="#consultoria" class="drawer-nav-link"
        >Consultoría y Asesoramiento</a
      >
      <a href="#gestores" class="drawer-nav-link">Gestores Externos</a>
      <a href="#sostenibilidad" class="drawer-nav-link">Sostenibilidad</a>

      <!-- Mobile-only En Línea section -->
      <div
        class="sm:hidden flex flex-col gap-4 mt-2 pt-4 border-t border-cream/20"
      >
        <a href="#" class="drawer-nav-link text-lg">Banca en Línea</a>
        <a href="#" class="drawer-nav-link text-lg">EVA</a>
      </div>
    </nav>
  </div>

  <div
    class="hidden sm:flex mt-8 pt-8 border-t border-cream/20 text-white! text-sm flex-col gap-4"
  >
    <div>
      <p class="font-bold text-white! uppercase mb-1">MMG Bank</p>
      <p class="text-white! text-p-small!">Panamá, República de Panamá</p>
    </div>
    <div>
      <p class="font-bold text-white! uppercase mb-1">Contacto</p>
      <a
        href="mailto:info@mmgbank.com"
        class="hover:text-white transition-colors text-p-small!"
        >info@mmgbank.com</a
      >
    </div>
  </div>
</div>

<style>
  .main-header {
    /* Fixed by default so position change does not break CSS transitions */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    transition:
      background-color 0.4s ease,
      padding-top 0.4s ease,
      padding-bottom 0.4s ease,
      box-shadow 0.4s ease;
  }

  .header-container {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    transition:
      max-width 0.4s ease,
      padding-left 0.4s ease,
      padding-right 0.4s ease;
  }

  /* Default transparent header state - aligns with hero card width */
  .main-header:not(.is-sticky) .header-container {
    padding-left: 0;
    padding-right: 0;
  }
  @media (max-width: 639.98px) {
    .main-header:not(.is-sticky) .header-container {
      max-width: calc(100% - 2rem);
    }
  }
  @media (min-width: 640px) and (max-width: 1023.98px) {
    .main-header:not(.is-sticky) .header-container {
      max-width: calc(100% - 3rem);
    }
  }
  @media (min-width: 1024px) {
    .main-header:not(.is-sticky) .header-container {
      max-width: min(calc(100% - 4rem), 1400px);
    }
  }

  /* Sticky header state (white background) - aligns with standard container-custom */
  .main-header.is-sticky .header-container {
    max-width: 400px;
    padding-left: var(--element-padding);
    padding-right: var(--element-padding);
  }
  @media (min-width: 640px) {
    .main-header.is-sticky .header-container {
      max-width: 800px;
    }
  }
  @media (min-width: 1024px) {
    .main-header.is-sticky .header-container {
      max-width: 1400px;
    }
  }

  .logo-link {
    color: var(--color-white);
    transition: color 0.4s ease;
  }

  /* Hamburger button default states */
  #menu-toggle {
    background-color: transparent;
    transition: transform 0.3s ease;
  }
  #menu-toggle .hamburger-line {
    background-color: var(--color-white);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease,
      background-color 0.4s ease;
  }

  /* Hamburger button active (open) state */
  .main-header.is-active-menu #menu-toggle .hamburger-line {
    background-color: var(--color-white) !important;
  }

  /* Hamburger button sticky state */
  .main-header.is-sticky #menu-toggle .hamburger-line {
    background-color: var(--color-darker-green) !important;
  }

  /* Hamburger Line Animation */
  #menu-toggle.is-active .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #menu-toggle.is-active .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scale(0);
  }
  #menu-toggle.is-active .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* When menu is open, modify header container styles */
  .main-header.is-active-menu {
    background-color: transparent !important;
    box-shadow: none !important;
  }
  .main-header.is-active-menu .logo-link {
    color: var(--color-white) !important;
  }

  /* Sticky class styling */
  .main-header.is-sticky {
    padding: 1rem 0px !important;
    background-color: var(--color-white) !important;
    transform: translateY(0) !important;
    opacity: 1 !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);

    /* Transition only enabled when sticky to prevent fighting GSAP scroll-scrub */
    transition:
      background-color 0.4s ease,
      padding-top 0.4s ease,
      padding-bottom 0.4s ease,
      box-shadow 0.4s ease,
      transform 0.4s ease,
      opacity 0.4s ease;
  }

  .main-header.is-sticky .logo-link {
    color: var(--color-primary) !important;
  }

  /* Drawer Navigation Links styles */
  .drawer-nav-link {
    font-family: "Bornia", sans-serif;
    color: var(--color-cream);
    transition:
      color 0.3s ease,
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-block;
  }
  .drawer-nav-link:hover {
    color: var(--color-white) !important;
    transform: translateX(12px);
  }

  /* Drawer Backdrop classes */
  #drawer-backdrop.is-active {
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* Drawer Menu Panel classes */
  #drawer-menu {
    background: var(--gradient-green);
  }
  #drawer-menu.is-active {
    transform: none !important;
    translate: 0 0 !important;
  }
</style>

<script>
  function initMenu() {
    const menuToggle = document.getElementById("menu-toggle");
    const drawerMenu = document.getElementById("drawer-menu");
    const drawerBackdrop = document.getElementById("drawer-backdrop");
    const mainHeader = document.querySelector(".main-header");
    const body = document.body;

    console.log("initMenu called:", {
      menuToggle,
      drawerMenu,
      drawerBackdrop,
      mainHeader,
    });

    if (menuToggle && drawerMenu && drawerBackdrop && mainHeader) {
      const toggle = menuToggle;
      const drawer = drawerMenu;
      const backdrop = drawerBackdrop;
      const header = mainHeader as HTMLElement;

      // Toggle menu state helper
      function toggleMenu(forceState?: boolean) {
        const isActive =
          typeof forceState === "boolean"
            ? forceState
            : !toggle.classList.contains("is-active");

        toggle.classList.toggle("is-active", isActive);
        drawer.classList.toggle("is-active", isActive);
        backdrop.classList.toggle("is-active", isActive);
        header.classList.toggle("is-active-menu", isActive);

        if (isActive) {
          const scrollbarWidth =
            window.innerWidth - document.documentElement.clientWidth;
          if (scrollbarWidth > 0) {
            body.style.setProperty(
              "padding-right",
              `${scrollbarWidth}px`,
              "important",
            );
            header.style.setProperty(
              "padding-right",
              `${scrollbarWidth}px`,
              "important",
            );
          }
          body.style.overflow = "hidden";
        } else {
          body.style.overflow = "";
          body.style.removeProperty("padding-right");
          header.style.removeProperty("padding-right");
        }
      }

      // Click on toggle button
      toggle.addEventListener("click", () => {
        toggleMenu();
      });

      // Click on backdrop
      backdrop.addEventListener("click", () => {
        toggleMenu(false);
      });

      // Close menu when clicking navigation links or contact button inside drawer
      const navLinks = drawer.querySelectorAll(".drawer-nav-link");
      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          toggleMenu(false);
        });
      });

      // Close drawer menu when clicking the En Línea dropdown toggle
      const enLineaToggle = document.getElementById("en-linea-toggle");
      if (enLineaToggle) {
        enLineaToggle.addEventListener("click", () => {
          toggleMenu(false);
        });
      }

      // Close menu on pressing Escape key
      window.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && toggle.classList.contains("is-active")) {
          toggleMenu(false);
        }
      });

      // Click logo to scroll back to top if on homepage, otherwise navigate
      const logoLink = document.querySelector(".logo-link");
      if (logoLink) {
        logoLink.addEventListener("click", (e) => {
          const path = window.location.pathname;
          if (path === "/" || path === "/index.html" || path.endsWith("/")) {
            e.preventDefault();
            toggleMenu(false);
            window.scrollTo({
              top: 0,
              behavior: "smooth",
            });
          }
        });
      }
    }
  }

  // Self initialize menu
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMenu);
  } else {
    initMenu();
  }
</script>
