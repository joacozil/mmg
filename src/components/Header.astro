---
import EnLineaDropdown from "./EnLineaDropdown.astro";
---

<header
  class="main-header fixed top-0 left-0 w-full py-4 lg:py-5 flex justify-between items-center z-999"
>
  <div class="header-container mx-auto w-full">
    <div
      class="flex sm:grid sm:grid-cols-3 items-center justify-between w-full relative"
    >
      <!-- Center: Logo (Left on mobile, Center on sm+) -->
      <div
        class="flex justify-start sm:justify-center sm:col-start-2 sm:row-start-1"
      >
        <a
          href="/"
          class="logo-link shrink-0 text-white z-1000 relative transition-colors duration-400"
          aria-label="MMG Bank Home"
        >
          <svg
            width="166"
            height="20"
            viewBox="0 0 166 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 md:h-6 w-auto"
          >
