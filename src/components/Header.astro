<style>
  .main-header {
    /* Fixed by default so position change does not break CSS transitions */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    transition:
      background-color 0.4s ease,
      padding 0.4s ease,
      box-shadow 0.4s ease;
  }

  .logo-link {
    color: var(--color-white);
    transition: color 0.4s ease;
  }

  nav a {
    transition: color 0.4s ease;
  }

  /* Sticky class styling */
  .main-header.is-sticky {
    padding: 1rem 1.5rem !important;
    background-color: var(--color-white) !important;
    transform: translateY(0) !important;
    opacity: 1 !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);

    /* Transition only enabled when sticky to prevent fighting GSAP scroll-scrub */
    transition:
      background-color 0.4s ease,
      padding 0.4s ease,
      box-shadow 0.4s ease,
      transform 0.4s ease,
      opacity 0.4s ease;
  }

  .main-header.is-sticky .logo-link {
    color: var(--color-primary) !important;
  }

  .main-header.is-sticky nav {
    color: var(--color-black) !important;
  }

  .main-header.is-sticky nav a:hover {
    color: var(--color-primary) !important;
  }
</style>
