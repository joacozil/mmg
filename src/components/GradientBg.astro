---
/**
 * GradientBg — Animated gradient background using CSS Custom Properties (@property).
 * Uses colors: #08291C, #00AC69, and #A6E2B9.
 *
 * Props:
 *   class  — Extra classes appended to the wrapper
 *   as     — HTML tag to render (default: "div")
 */
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { as: Tag = "div", class: className } = Astro.props;
