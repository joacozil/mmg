---
// src/components/Footer.astro
import { Image } from "astro:assets";
import facebookIcon from "../assets/img/facebook.svg";
import instagramIcon from "../assets/img/instagram.svg";
import linkedinIcon from "../assets/img/linkedin.svg";
---

<footer
  class="w-full bg-darker-green py-4 md:py-6 lg:py-8 relative overflow-hidden"
>
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch">
      <!-- Left Card: Links, Logo and Social Media -->
      <div
        class="lg:col-span-8 bg-cream p-8 lg:p-12 rounded-[24px] flex flex-col justify-between"
      >
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Column 1: Links (Clientes, Soluciones, Servicios) -->
          <div class="flex flex-col gap-6">
            <div>
              <h4
                class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors cursor-pointer mb-3"
              >
                Clientes
              </h4>
              <ul class="flex flex-col gap-2">
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Individuales</a
                  >
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Corporativo</a
                  >
                </li>
              </ul>
            </div>

            <div>
              <h4
                class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors cursor-pointer mb-3"
              >
                Soluciones de Inversión
              </h4>
              <ul class="flex flex-col gap-2">
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Hub</a
                  >
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Cliente Individual</a
                  >
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Fondos Comunes</a
                  >
                </li>
              </ul>
            </div>

            <div>
              <h4
                class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors cursor-pointer mb-3"
              >
                Servicios Bancarios
              </h4>
              <ul class="flex flex-col gap-2">
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Hub</a
                  >
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Cliente Individual</a
                  >
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Tarjeta De Crédito</a
                  >
                </li>
              </ul>
            </div>

            <div>
              <a
                href="#"
                class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors block"
              >
                Consultoría y Asesoramiento
              </a>
            </div>

            <div>
              <h4
                class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors cursor-pointer mb-3"
              >
                Gestores Externos
              </h4>
              <ul class="flex flex-col gap-2">
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Soluciones</a
                  >
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors"
                    >Herramientas</a
                  >
                </li>
              </ul>
            </div>

            <div>
              <a
                href="#"
                class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors block"
              >
                Sostenibilidad
              </a>
            </div>
          </div>

          <!-- Column 2: Links (Enlaces Importantes) -->
          <div class="flex flex-col gap-6">
            <div>
              <h4
                class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors cursor-pointer mb-3"
              >
                Enlaces Importantes
              </h4>
              <ul class="flex flex-col gap-2.5">
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors inline-flex items-center gap-2"
                  >
                    Reportes Anónimos
                  </a>
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors inline-flex items-center gap-2"
                  >
                    Sistemas de Denuncias
                  </a>
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors inline-flex items-center gap-2"
                  >
                    Atención de Reclamos
                  </a>
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors inline-flex items-center gap-2"
                  >
                    Código de Ética
                  </a>
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors inline-flex items-center gap-2"
                  >
                    Aviso de Privacidad y Seguridad
                  </a>
                </li>
                <li>
                  <a
                    href="#"
                    class="text-p-small text-black hover:text-primary transition-colors inline-flex items-start gap-2"
                  >
                    MMG Bank International,<br />
                    Inc. Disclosures
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <!-- Column 3: MMG Bank Logo & Social Media Icons -->
          <div
            class="flex flex-col justify-between items-center md:items-end h-full min-h-[160px] md:min-h-0"
          >
            <!-- Brand Logo -->
            <a
              href="/"
              aria-label="MMG Bank Home"
              class="text-primary hover:opacity-85 transition-opacity"
            >
              <svg
                width="166"
                height="20"
                viewBox="0 0 166 20"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-auto"
              >
                <path
                  d="M61.5573 2.29688L57.8296 14.8842L54.0221 2.29688H50.6635L48.1504 18.1717H50.8211L52.7258 5.87856L56.4535 18.1717H59.098L62.8277 5.87856L64.7305 18.1717H67.4289L64.942 2.29688H61.5573Z"
                  fill="currentColor"></path>
                <path
                  d="M83.4263 2.29688L79.6986 14.8842L75.8911 2.29688H72.5324L70.0195 18.1717H72.6901L74.5947 5.87856L78.3224 18.1717H80.967L84.6966 5.87856L86.5995 18.1717H89.2978L86.8109 2.29688H83.4263Z"
                  fill="currentColor"></path>
                <path
                  d="M100.008 9.09151V11.2937H102.391V15.687C101.755 15.9549 101.043 16.0617 100.064 16.0617C96.9701 16.0617 94.5908 13.764 94.5908 10.2367C94.5908 6.70945 96.8923 4.49024 100.064 4.49024C101.783 4.49024 103.396 5.105 104.507 6.14709V3.2345C103.239 2.46045 101.705 2.03125 99.9319 2.03125C95.2789 2.03125 91.8145 5.37114 91.8145 10.2348C91.8145 15.0984 95.1193 18.4383 100.012 18.4383C101.942 18.4383 103.847 18.0373 105.09 17.2631V9.09151H100.008Z"
                  fill="currentColor"></path>
                <path
                  d="M117.86 16.1669C117.517 16.1669 116.96 16.1405 116.458 16.088V11.303H118.151C120.293 11.303 121.693 11.9704 121.693 13.6816C121.693 15.3927 120.397 16.1669 117.86 16.1669ZM116.458 4.40965C116.88 4.35718 117.489 4.30283 117.938 4.30283C119.868 4.30283 121.057 5.05065 121.057 6.60058C121.057 8.23132 119.92 9.0859 117.724 9.0859H116.456V4.40965H116.458ZM120.662 9.99486C122.433 9.72688 123.73 8.3925 123.73 6.44137C123.73 3.39568 121.508 2.03125 117.78 2.03125C116.591 2.03125 114.976 2.19243 113.839 2.35174V18.1198C114.87 18.279 116.246 18.414 117.515 18.414C122.407 18.414 124.416 16.5978 124.416 13.8165C124.416 11.5186 122.91 10.1822 120.66 9.99486"
                  fill="currentColor"></path>
                <path
                  d="M133.962 16.3037C133.485 16.3843 132.93 16.4367 132.534 16.4367C130.946 16.4367 129.837 15.9569 129.837 14.7256C129.837 13.4942 131.028 12.99 132.851 12.99H133.962V16.3037ZM132.139 6.07031C130.685 6.07031 129.362 6.44519 128.331 7.03179V9.32952C129.31 8.76912 130.367 8.36814 131.716 8.36814C133.064 8.36814 133.963 8.95671 133.963 10.2387V11.2282H132.667C129.282 11.2282 127.246 12.4034 127.246 14.8079C127.246 17.4806 129.468 18.416 132.508 18.416C133.83 18.416 135.416 18.2286 136.527 17.9362V10.1055C136.527 7.13859 134.701 6.07031 132.137 6.07031"
                  fill="currentColor"></path>
                <path
                  d="M145.97 6.07031C144.25 6.07031 142.242 6.44519 140.601 7.08617V18.176H143.219V8.82174C143.907 8.60794 144.833 8.47494 145.758 8.47494C147.212 8.47494 148.271 9.08972 148.271 10.8008V18.176H150.862V10.5591C150.862 7.21918 148.957 6.07031 145.97 6.07031Z"
                  fill="currentColor"></path>
                <path
                  d="M165.366 18.1726L160.105 11.7046L165.261 6.33303H162.036L157.605 11.1929V0H154.986V18.1726H157.605V12.4L162.245 18.1726H165.366Z"
                  fill="currentColor"></path>
                <path
                  d="M14.0725 10.3365C9.59369 2.07293 0 2.30535 0 2.30535C2.96917 3.36804 7.29772 10.7694 7.34422 10.8575C11.8266 19.1191 21.4205 18.8831 21.4205 18.8831C18.4457 17.8185 14.1226 10.4246 14.0725 10.3383"
                  fill="currentColor"></path>
                <path
                  d="M35.6133 9.62175C31.1364 1.35828 21.5537 1.59444 21.5537 1.59444C24.5082 2.65527 28.8442 10.0549 28.8867 10.1429C33.3675 18.4064 42.9556 18.1683 42.9556 18.1683C39.9845 17.1037 35.6598 9.70983 35.6133 9.62373"
                  fill="currentColor"></path>
                <path
                  d="M25.3856 9.8522C25.4469 9.959 30.5693 18.7344 34.0911 19.9976C34.0911 19.9976 22.7113 20.2806 17.4017 10.4782C17.3429 10.3771 12.2051 1.59622 8.69629 0.336735C8.69629 0.336735 20.0673 0.059336 25.3856 9.85417"
                  fill="currentColor"></path>
              </svg>
            </a>

            <!-- Social Media Links -->
            <div class="flex items-center gap-6 select-none mt-8 md:mt-0">
              <a
                href="https://www.linkedin.com"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:scale-105 transition-transform duration-300"
              >
                <Image src={linkedinIcon} alt="LinkedIn" class="w-10 h-10" />
              </a>
              <a
                href="https://www.facebook.com"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:scale-105 transition-transform duration-300"
              >
                <Image src={facebookIcon} alt="Facebook" class="w-10 h-10" />
              </a>
              <a
                href="https://www.instagram.com"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:scale-105 transition-transform duration-300"
              >
                <Image src={instagramIcon} alt="Instagram" class="w-10 h-10" />
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Card: Contact Addresses -->
      <div
        class="lg:col-span-4 bg-light-green p-8 lg:p-12 rounded-[24px] flex flex-col gap-10 text-darker-green"
      >
        <!-- Panamá Info -->
        <div>
          <h4
            class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors cursor-pointer mb-2"
          >
            Panamá
          </h4>
          <p class="text-p-small! font-bold text-darker-green mb-3">
            MMG Bank Corporation
          </p>

          <ul class="flex flex-col gap-3.5">
            <li class="flex items-start gap-2.5 text-p-small text-darker-green">
              <!-- Map Pin Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 shrink-0 mt-0.5 text-darker-green"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                ></path>
              </svg>
              <span class="leading-normal"
                >Ave. Paseo del Mar. Costa del Este MMG Tower, Piso 22, Ciudad
                de Panamá, República de Panamá.</span
              >
            </li>

            <li class="flex items-start gap-2.5 text-p-small text-darker-green">
              <!-- Phone Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 shrink-0 mt-0.5 text-darker-green"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.802-5.184-4.162-6.986-6.986l1.293-.97c.362-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                ></path>
              </svg>
              <a href="tel:+5072657600" class="hover:underline leading-normal"
                >+507 265 7600</a
              >
            </li>

            <li class="flex items-start gap-2.5 text-p-small text-darker-green">
              <!-- Mail Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 shrink-0 mt-0.5 text-darker-green"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25H4.5a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5H4.5a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                ></path>
              </svg>
              <a
                href="mailto:info@mmgbank.com"
                class="hover:underline leading-normal">info@mmgbank.com</a
              >
            </li>

            <li class="flex items-start gap-2.5 text-p-small text-darker-green">
              <!-- Clock Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 shrink-0 mt-0.5 text-darker-green"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
              </svg>
              <span class="leading-normal">Lun-Vie: 8:00 a.m. - 3:00 p.m.</span>
            </li>
          </ul>
        </div>

        <!-- Puerto Rico Info -->
        <div>
          <h4
            class="text-p-small! font-bold uppercase text-black hover:text-primary transition-colors cursor-pointer mb-2"
          >
            Puerto Rico
          </h4>
          <p class="text-p-small! font-bold text-darker-green mb-3">
            MMG Bank International, Inc.
          </p>

          <ul class="flex flex-col gap-3.5">
            <li class="flex items-start gap-2.5 text-p-small text-darker-green">
              <!-- Map Pin Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 shrink-0 mt-0.5 text-darker-green"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                ></path>
              </svg>
              <span class="leading-normal"
                >250 Muñoz Rivera Avenue. Suite 315, San Juan, Puerto Rico
                00918.</span
              >
            </li>

            <li class="flex items-start gap-2.5 text-p-small text-darker-green">
              <!-- Phone Icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 shrink-0 mt-0.5 text-darker-green"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.802-5.184-4.162-6.986-6.986l1.293-.97c.362-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                ></path>
              </svg>
