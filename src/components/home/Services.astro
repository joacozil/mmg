---
import { Image } from "astro:assets";
import LinkMore from "../LinkMore.astro";

import image2 from "../../assets/img/happy-couple-signing-contract-meeting-with-their-real-estate-agent-office 1.jpg";
import image3 from "../../assets/img/cropped-colleagues-generating-business-ideas 1.jpg";
import image1 from "../../assets/img/young-business-people-working 1.jpg";

const services = [
  {
    title: "Soluciones de inversión",
    text: "Como sus gestores de activos, en MMG Bank nos enfocamos en optimizar sus portafolios y resguardar su capital mediante <strong>estrategias sólidas y diversificadas.</strong>",
    image: image1,
    href: "#",
    position: "object-bottom",
  },
  {
    title: "Servicios bancarios",
    text: "Respaldamos sus metas con una <strong>infraestructura operativa y de financiamiento sólida</strong>, diseñada exclusivamente para que usted proteja y preserve su capital con total tranquilidad.",
    image: image2,
    href: "#",
    position: "object-[50%_85%]",
  },
  {
    title: "Asesoría corporativa y estratégica",
    text: "Respondemos con precisión a sus necesidades de crecimiento, financiamiento y estructura en la región. Le ofrecemos un <strong>respaldo estratégico y solidez indispensables</strong> para asegurar su expansión y liderazgo en el mercado.",
    image: image3,
    href: "#",
    position: "object-center",
  },
];
---

<section data-services-section class="w-full bg-cream py-section-gap overflow-hidden">
  <div class="container-custom">
    
    <!-- Desktop/Tablet Layout: Vertical stack of horizontal banner cards (768px and wider) -->
    <div class="hidden md:flex flex-col gap-6">
      {
        services.map((service, i) => (
          <div data-service-row class="grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch">
            <!-- Image Container -->
            <div data-service-image class="md:col-span-8 relative min-h-[220px] md:min-h-0 overflow-hidden">
              <Image
                src={service.image}
                alt={service.title}
                class={`w-full h-full object-cover md:absolute md:inset-0 ${service.position || "object-center"}`}
              />
            </div>

            <!-- Content Card -->
            <div data-service-card class="md:col-span-4 flex">
              <div class="bg-white p-6 md:p-8 flex flex-col justify-between w-full h-full">
                <div>
                  <p class="text-darker-green uppercase font-bold text-p-large! mb-3">
                    {service.title}
                  </p>
                  <p class="text-p-small!" set:html={service.text} />
                </div>
                <div class="mt-6">
                  <LinkMore href={service.href} />
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Mobile Layout: Swipeable Swiper Slider (below 768px) -->
    <div class="block md:hidden">
      <div data-services-mobile-swiper class="swiper services-swiper overflow-visible!">
        <div class="swiper-wrapper">
          {
            services.map((service) => (
              <div class="swiper-slide h-auto">
                <div class="flex flex-col h-full bg-white w-full">
                  <!-- Image Container -->
                  <div class="aspect-3/2 w-full overflow-hidden relative">
                    <Image
                      src={service.image}
                      alt={service.title}
                      class={`w-full h-full object-cover ${service.position || "object-center"}`}
                    />
                  </div>

                  <!-- Content Card -->
                  <div class="p-6 flex flex-col justify-between flex-1">
                    <div>
                      <p class="text-darker-green uppercase font-bold text-p-large! mb-3">
                        {service.title}
                      </p>
                      <p class="text-p-small!" set:html={service.text} />
                    </div>
                    <div class="mt-6">
                      <LinkMore href={service.href} />
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .swiper-slide {
    display: flex;
    height: auto;
  }
</style>

<script>
  import Swiper from "swiper";
  import "swiper/css";

  // Initialize Swiper on component load for services
  new Swiper(".services-swiper", {
    slidesPerView: 1.15,
    spaceBetween: 16,
    observer: true,
    observeParents: true,
    breakpoints: {
      640: {
        slidesPerView: 2.2,
        spaceBetween: 20,
      },
    },
  });
</script>
