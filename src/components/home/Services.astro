---
import { Image } from "astro:assets";
import LinkMore from "../LinkMore.astro";

import image2 from "../../assets/img/happy-couple-signing-contract-meeting-with-their-real-estate-agent-office 1.jpg";
import image3 from "../../assets/img/cropped-colleagues-generating-business-ideas 1.jpg";
import image1 from "../../assets/img/young-business-people-working 1.jpg";

const services = [
  {
    title: "Soluciones de inversión",
    text: "Como sus gestores de activos, en MMG Bank nos enfocamos en optimizar sus portafolios y resguardar su capital mediante <strong>estrategias sólidas y diversificadas.</strong>",
    image: image1,
    href: "#",
    position: "object-bottom",
  },
  {
    title: "Servicios bancarios",
    text: "Respaldamos sus metas con una <strong>infraestructura operativa y de financiamiento sólida</strong>, diseñada exclusivamente para que usted proteja y preserve su capital con total tranquilidad.",
    image: image2,
    href: "#",
    position: "object-[50%_85%]",
  },
  {
    title: "Asesoría corporativa y estratégica",
    text: "Respondemos con precisión a sus necesidades de crecimiento, financiamiento y estructura en la región. Le ofrecemos un <strong>respaldo estratégico y solidez indispensables</strong> para asegurar su expansión y liderazgo en el mercado.",
    image: image3,
    href: "#",
    position: "object-center",
  },
];
---

<section data-services-section class="w-full bg-cream py-section-gap overflow-hidden">
  <div class="container-custom">
    
    <!-- Desktop/Tablet Layout: Vertical stack of horizontal banner cards (768px and wider) -->
    <div class="hidden md:flex flex-col gap-6">
      {
        services.map((service, i) => (
          <div data-service-row class="grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch">
            <!-- Image Container -->
            <div data-service-image class="md:col-span-8 relative min-h-[220px] md:min-h-0 overflow-hidden">
              <Image
                src={service.image}
                alt={service.title}
                class={`w-full h-full object-cover md:absolute md:inset-0 ${service.position || "object-center"}`}
              />
            </div>

            <!-- Content Card -->
            <div data-service-card class="md:col-span-4 flex">
              <div class="bg-white p-6 md:p-8 flex flex-col justify-between w-full h-full">
                <div>
                  <p class="text-darker-green uppercase font-bold text-p-large! mb-3">
                    {service.title}
                  </p>
                  <p class="text-p-small!" set:html={service.text} />
                </div>
                <div class="mt-6">
                  <LinkMore href={service.href} />
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Mobile Layout: Swipeable Swiper Slider (below 768px) -->
    <div class="block md:hidden">
      <div data-services-mobile-swiper class="swiper services-swiper overflow-visible!">
        <div class="swiper-wrapper">
          {
            services.map((service) => (
              <div class="swiper-slide h-auto">
                <div class="flex flex-col h-full bg-white w-full">
                  <!-- Image Container -->
                  <div class="aspect-3/2 w-full overflow-hidden relative">
                    <Image
                      src={service.image}
                      alt={service.title}
                      class={`w-full h-full object-cover ${service.position || "object-center"}`}
                    />
                  </div>

                  <!-- Content Card -->
                  <div class="p-6 flex flex-col justify-between flex-1">
                    <div>
                      <p class="text-darker-green uppercase font-bold text-p-large! mb-3">
                        {service.title}
                      </p>
                      <p class="text-p-small!" set:html={service.text} />
                    </div>
                    <div class="mt-6">
                      <LinkMore href={service.href} />
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .swiper-slide {
    display: flex;
    height: auto;
  }
</style>

<script>
  import Swiper from "swiper";
  import "swiper/css";

  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Initialize Swiper on component load for services
  new Swiper(".services-swiper", {
    slidesPerView: 1.15,
    spaceBetween: 16,
    observer: true,
    observeParents: true,
    breakpoints: {
      640: {
        slidesPerView: 2.2,
        spaceBetween: 20,
      },
    },
  });

  const section = document.querySelector<HTMLElement>("[data-services-section]");
  if (section && !prefersReduced) {
    const desktopRows = section.querySelectorAll<HTMLElement>("[data-service-row]");
    const mobileSwiper = section.querySelector<HTMLElement>("[data-services-mobile-swiper]");

    // Set initial hidden states immediately to avoid visual jump (FOUC)
    desktopRows.forEach((row) => {
      const image = row.querySelector<HTMLElement>("[data-service-image]");
      const card = row.querySelector<HTMLElement>("[data-service-card]");

      if (image) {
        gsap.set(image, { opacity: 0, x: -40 });
      }
      if (card) {
        gsap.set(card, { opacity: 0, x: 40 });
      }
    });

    if (mobileSwiper) {
      const slides = mobileSwiper.querySelectorAll<HTMLElement>(".swiper-slide");
      if (slides.length > 0) {
        gsap.set(slides, { opacity: 0, y: 30 });
      }
    }

    const createTriggers = () => {
      // 1. Create separate ScrollTriggers for each desktop card row
      desktopRows.forEach((row, i) => {
        const image = row.querySelector<HTMLElement>("[data-service-image]");
        const card = row.querySelector<HTMLElement>("[data-service-card]");

        ScrollTrigger.create({
          trigger: row,
          start: "top 60%", // trigger at top 60% of viewport
          once: true,
          onEnter: () => {
            const tl = gsap.timeline();
            if (image) {
              tl.to(image, {
                opacity: 1,
                x: 0,
                duration: 0.9,
                ease: "power3.out",
              }, 0);
            }
            if (card) {
              tl.to(card, {
                opacity: 1,
                x: 0,
                duration: 0.9,
                ease: "power3.out",
              }, 0.05); // small stagger
            }
          },
        });
      });

      // 2. Create ScrollTrigger for mobile swiper
      if (mobileSwiper) {
        const slides = mobileSwiper.querySelectorAll<HTMLElement>(".swiper-slide");
        if (slides.length > 0) {
          ScrollTrigger.create({
            trigger: mobileSwiper,
            start: "top 60%",
            once: true,
            onEnter: () => {
              gsap.to(slides, {
                opacity: 1,
                y: 0,
                duration: 0.8,
                stagger: 0.1,
                ease: "power3.out",
              });
            },
          });
        }
      }

      // Recalculate ScrollTrigger coordinates now that Hero pin is set up
      ScrollTrigger.refresh();
    };

    const initTriggers = () => {
      // Defer to allow React hydration/rendering and pin spacing layout to settle completely
      requestAnimationFrame(() => {
        setTimeout(createTriggers, 100);
      });
    };

    // Initialize ScrollTriggers immediately if Hero is already loaded, otherwise wait
    if ((window as any).heroScrollTriggerInitialized) {
      initTriggers();
    } else {
      window.addEventListener("hero-scroll-trigger-init", initTriggers, { once: true });
    }
  }
</script>
