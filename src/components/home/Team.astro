---
import { Image } from "astro:assets";
import SplitRow from "../SplitRow.astro";

// Import images from src/assets/img/team
import img1 from "../../assets/img/team/Gemini_Generated_Image_1ralm61ralm61ral 2.jpg";
import img2 from "../../assets/img/team/Gemini_Generated_Image_1ralm61ralm61ral-2 2.jpg";
import img3 from "../../assets/img/team/Gemini_Generated_Image_1ralm61ralm61ral-3 2.jpg";
import img4 from "../../assets/img/team/Gemini_Generated_Image_1ralm61ralm61ral-4 2.jpg";
import img5 from "../../assets/img/team/Gemini_Generated_Image_28194f28194f2819 2.jpg";
import img6 from "../../assets/img/team/Gemini_Generated_Image_asbb9basbb9basbb 2.jpg";
import img7 from "../../assets/img/team/Gemini_Generated_Image_bl49h6bl49h6bl49 2.jpg";
import img8 from "../../assets/img/team/Gemini_Generated_Image_kiawuxkiawuxkiaw 2.jpg";

const teamMembers = [
  {
    name: "Jorge Enrique Morgan V.",
    role: "Presidente Ejecutivo de MMG Bank",
    imageSrc: img1,
  },
  {
    name: "María Eugenia Espino",
    role: "VP Administración, Contabilidad y Operaciones",
    imageSrc: img2,
  },
  {
    name: "Carlos Eduardo Troetsch",
    role: "Vicepresidente Ejecutivo",
    imageSrc: img3,
  },
  {
    name: "Jorge Vallarino Ferrer",
    role: "VP Tesorería y Relaciones Institucionales",
    imageSrc: img4,
  },
  { name: "Maricarmen Sosa", role: "VP Banca de Inversión", imageSrc: img5 },
  { name: "Luis Navarro", role: "VP Gestión Patrimonial", imageSrc: img6 },
  { name: "Ana Isabel Domínguez", role: "VP Cumplimiento", imageSrc: img7 },
  { name: "Roberto Brenes", role: "Director General", imageSrc: img8 },
];
---

<section
  id="team-section"
  data-team-section
  class="pt-0 pb-section-gap bg-cream relative overflow-hidden"
>
  <div class="container-custom mb-12 lg:mb-16">
    <div data-team-header>
      <SplitRow
        title="30 años contribuyendo al desarrollo sostenible y crecimiento de Panamá"
        text="Trabajamos día a día con una visión clara: ser sus líderes de confianza en asesoría financiera en Panamá, con el respaldo de un reconocimiento local e internacional como la <strong>firma líder panameña</strong> en administración de activos."
      />
    </div>
  </div>

  <div class="container-custom">
    <!-- Swiper container -->
    <div class="swiper team-swiper overflow-visible!">
      <div class="swiper-wrapper">
        {
          teamMembers.map((member) => (
            <div class="swiper-slide team-card shrink-0 flex flex-col gap-4">
              <div class="w-full aspect-square overflow-hidden rounded-md bg-light-green">
                <Image
                  src={member.imageSrc}
                  alt={member.name}
                  class="w-full h-full object-cover object-center"
                />
              </div>
              <div class="flex flex-col justify-center">
                <span class="block text-p-small! uppercase text-gray-500">
                  {member.role}
                </span>
                <span class="block font-bold text-p-large! mt-1 text-primary">
                  {member.name}
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
    <!-- Custom lines-based pagination indicator container -->
    <div class="team-pagination"></div>
  </div>
</section>

<style>
  /* Swiper slide stretching */
  .swiper-slide {
    display: flex;
    height: auto;
  }

  /* Responsive card widths since we use slidesPerView: "auto" */
  .team-card {
    width: 220px;
  }
  @media (min-width: 640px) {
    .team-card {
      width: 260px;
    }
  }
  @media (min-width: 1024px) {
    .team-card {
      width: 300px;
    }
  }

  /* Custom Premium Lines Pagination */
  .team-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 3rem;
    position: relative;
    z-index: 10;
  }

  :global(.team-pagination .swiper-pagination-bullet) {
    width: 24px;
    height: 3px;
    background-color: rgba(18, 71, 52, 0.25) !important;
    border-radius: 0 !important;
    margin: 0 !important;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    opacity: 1 !important;
    cursor: pointer;
  }

  :global(.team-pagination .swiper-pagination-bullet-active) {
    width: 48px;
    background-color: var(--color-primary) !important;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Autoplay, Pagination } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/autoplay";
  import "swiper/css/pagination";
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Initialize Swiper on page load
  const swiperEl = document.querySelector(".team-swiper") as HTMLElement | null;

  if (swiperEl) {
    const swiper = new Swiper(".team-swiper", {
      modules: [Autoplay, Pagination],
      loop: false,
      rewind: true,
      speed: 800,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      pagination: {
        el: ".team-pagination",
        type: "bullets",
        clickable: true,
      },
      slidesPerView: "auto",
      spaceBetween: 24,
      breakpoints: {
        1024: {
          spaceBetween: 32,
        },
      },
    });

    // Pause autoplay initially
    swiper.autoplay.stop();

    let animationDone = false;
    if (prefersReduced) {
      animationDone = true;
    }

    // Use Intersection Observer to play only when visible and animation is done
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && animationDone) {
          swiper.autoplay.start();
        } else {
          swiper.autoplay.stop();
        }
      });
    }, { threshold: 0.1 });

    observer.observe(swiperEl);

    // Setup animations if not prefersReduced
    if (!prefersReduced) {
      const section = document.querySelector<HTMLElement>("[data-team-section]");
      const header = section?.querySelector<HTMLElement>("[data-team-header]");
      const cards = section?.querySelectorAll<HTMLElement>(".team-card");
      
      if (header) {
        gsap.set(header, { opacity: 0, y: 30 });
      }
      if (cards && cards.length > 0) {
        gsap.set(cards, { opacity: 0, y: 40 });
      }

      const bullets = document.querySelectorAll(".team-pagination .swiper-pagination-bullet");
      if (bullets.length > 0) {
        gsap.set(bullets, { opacity: 0, y: 15 });
      }

      const createTriggers = () => {
        if (section) {
          ScrollTrigger.create({
            trigger: section,
            start: "top 60%", // trigger at top 60% of viewport
            once: true,
            onEnter: () => {
              const tl = gsap.timeline();

              // 1. Header fade & rise
              if (header) {
                tl.to(header, {
                  opacity: 1,
                  y: 0,
                  duration: 0.9,
                  ease: "power3.out",
                }, 0);
              }

              // 2. Team cards stagger fade & rise
              if (cards && cards.length > 0) {
                tl.to(cards, {
                  opacity: 1,
                  y: 0,
                  duration: 1.0,
                  stagger: 0.08,
                  ease: "power3.out",
                  onComplete: () => {
                    animationDone = true;
                    // If currently intersecting, start autoplay
                    if (swiperEl.getBoundingClientRect().top < window.innerHeight && swiperEl.getBoundingClientRect().bottom > 0) {
                      swiper.autoplay.start();
                    }
                  }
                }, 0.15);
              } else {
                animationDone = true;
              }

              // 3. Pagination bullets stagger
              const liveBullets = section.querySelectorAll(".team-pagination .swiper-pagination-bullet");
              if (liveBullets.length > 0) {
                tl.to(liveBullets, {
                  opacity: 1,
                  y: 0,
                  duration: 0.6,
                  stagger: 0.08,
                  ease: "power3.out",
                }, "-=0.6");
              }
            }
          });
        }

        ScrollTrigger.refresh();
      };

      const initTriggers = () => {
        // Defer to allow React hydration/rendering and pin spacing layout to settle completely
        requestAnimationFrame(() => {
          setTimeout(createTriggers, 100);
        });
      };

      // Initialize triggers after Hero is ready
      if ((window as any).heroScrollTriggerInitialized) {
        initTriggers();
      } else {
        window.addEventListener("hero-scroll-trigger-init", initTriggers, { once: true });
      }
    }
  }
</script>
